source "Kconfig.zephyr"

menu "CUBS2"

config CUBS2_FASTDYN
	bool "Enable FastDyn hardware-target adapters"
	default n
	select CUBS2_SIM_TRANSPORT
	help
	  Retain the mr_vmu_tropic Cortex-M7 image, linker layout, Zephyr kernel,
	  Ethernet driver, and CUBS2 application while bypassing physical-only
	  board sequencing and analog clock setup during FastDyn/QEMU rehosting.

choice CUBS2_EXECUTION_MODE
	prompt "Controller execution mode"
	default CUBS2_LOCKSTEP if CUBS2_FASTDYN
	default CUBS2_REALTIME

config CUBS2_REALTIME
	bool "Realtime"
	help
	  Pace the controller on wall time. Deployed and native_sim builds consume
	  the direct Zenoh mocap pose stream. FastDyn consumes odometry through its
	  direct shared-memory simulation transport; its host bridge owns wall-time
	  pacing because Zephyr uptime is QEMU virtual time under FastDyn.

config CUBS2_LOCKSTEP
	bool "Deterministic lockstep"
	depends on BOARD_NATIVE_SIM || CUBS2_FASTDYN
	select CUBS2_SIM_TRANSPORT
	help
	  Advance the controller from simulator timestamps without wall-clock
	  pacing. Generated synapse_fbs payload structs use direct shared memory;
	  CSyn and ZROS may run concurrently as an independent side channel.

endchoice

config CUBS2_SIM_TRANSPORT
	bool
	select CEREBRI_LOCKSTEP
	help
	  Internal direct shared-memory transport used by native_sim lockstep and
	  both FastDyn execution modes.

config CUBS2_RUNTIME_CONTROL
	bool "Enable Zenoh runtime configuration services"
	depends on CSYN_ZENOH
	default y
	help
	  Register param_get, param_set, and trajectory_set queryable services.
	  Updates are staged by the Zenoh thread and applied at a controller-cycle
	  boundary. Network-free FastDyn builds leave this disabled automatically;
	  enabling the Zenoh side channel makes the services available again.

config CUBS2_MANUAL_OVERRIDE
	bool "Select manual or autonomous RC output from incoming RC switch"
	default y
	help
	  Mirror the CUBS2 fixed-wing bridge behavior: keep both the incoming
	  manual RC channels and the generated autonomous channels, then publish
	  manual channels when the mode switch is low and autonomous channels
	  when the mode switch is high. If manual channels or the switch do not
	  look like valid PWM values, the controller stays on autonomous output.

config CUBS2_AUTO_SWITCH_CHANNEL
	int "Incoming RC channel index used for manual/autonomous switch"
	depends on CUBS2_MANUAL_OVERRIDE
	default 4
	range 0 15
	help
	  Zero-based internal PWM channel index used as the source mode switch.
	  The manual-control bridge encodes flight mode on channel 4; channel 5
	  is reserved for the independent stabilization/active switch.

config CUBS2_AUTO_SWITCH_THRESHOLD_US
	int "Manual/autonomous switch PWM threshold"
	depends on CUBS2_MANUAL_OVERRIDE
	default 1500
	range 1000 2000
	help
	  Switch values above this threshold select autonomous output. Values at
	  or below this threshold select manual passthrough.

endmenu
